{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "composite": true,
    "lib": ["ES2022"],
    "types": ["node"],
    "outDir": "./out/tsbuildinfo/node"
  },
  "include": [
    "src/main/**/*.ts",
    "src/preload/**/*.ts",
    "src/shared/**/*.ts",
    "plugins/**/*.ts",
    "electron.vite.config.ts",
    "eslint.config.js",
    "vitest.config.ts"
  ]
}
